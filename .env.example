# Shared
NODE_ENV=development
APP_NAME=clinic-brain

# Backend
PORT=3000
API_PREFIX=/api
LOG_LEVEL=info
SESSION_TIMEOUT_MINUTES=120
JWT_SECRET=change_me_with_32_chars_minimum
JWT_EXPIRES_IN=1d
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
CORS_ORIGIN=http://localhost:5173
WEBHOOK_API_KEY=change_me_webhook_key

# Database (postgres:postgres é padrão do docker-compose para dev local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5454/clinic_brain

# Evolution API
EVOLUTION_URL=http://localhost:8080
EVOLUTION_API_KEY=change_me_evolution_key
EVOLUTION_INSTANCE=automation
EVOLUTION_TIMEOUT_MS=5000
EVOLUTION_RETRY_ATTEMPTS=2
BOOKING_SITE_URL=http://localhost:5173
SCHEDULER_ENABLED=true
REMINDER_CHECK_INTERVAL_MS=60000
DEFAULT_TIMEZONE=America/Sao_Paulo

# Google Calendar / Meet
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=change_me_google_token_encryption_key_32chars
GOOGLE_SYNC_ENABLED=true
GOOGLE_SYNC_CHECK_INTERVAL_MS=30000
GOOGLE_SYNC_BATCH_SIZE=20
GOOGLE_SYNC_MAX_ATTEMPTS=6
GOOGLE_FRONTEND_SUCCESS_URL=http://localhost:5173/settings?google=connected
GOOGLE_FRONTEND_ERROR_URL=http://localhost:5173/settings?google=error

# Frontend
VITE_API_URL=http://localhost:3000/api
